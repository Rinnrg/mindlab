generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String              @id @default(uuid()) @db.Uuid
  username          String?             @unique @db.VarChar(255)
  email             String              @unique @db.VarChar(255)
  nama              String              @db.VarChar(255)
  password          String?             @db.VarChar(255)
  role              Role                @default(SISWA)
  foto              String?             @db.VarChar(255)
  kelas             String?             @db.VarChar(255)
  createdAt         DateTime            @default(now())
  anggotaKelompok   AnggotaKelompok[]
  asesmenDibuat     Asesmen[]
  balasanForum      BalasanForum[]
  course            Course[]
  enrollments       Enrollment[]
  forumDiskusi      ForumDiskusi[]
  jawabanSiswa      JawabanSiswa[]
  nilai             Nilai[]
  pengumpulanProyek PengumpulanProyek[]
  profileShowcase   ProfileShowcase[]
  masalahDibuat     PBL[]               @relation("PBLDibuat")
}

model Course {
  id          String       @id @default(uuid()) @db.Uuid
  judul       String       @db.VarChar(255)
  deskripsi   String?      @db.VarChar(1000)
  // Can be a URL or a base64 data URL from the thumbnail upload preview.
  // Base64 strings can be very long. Use TEXT in Postgres to avoid length limits.
  gambar      String       @db.Text
  kategori    String       @db.VarChar(255)
  guruId      String       @db.Uuid
  asesmen     Asesmen[]
  guru        User         @relation(fields: [guruId], references: [id])
  enrollments Enrollment[]
  materi      Materi[]

  @@index([guruId])
  @@index([kategori])
}

model Materi {
  id          String   @id @default(uuid()) @db.Uuid
  judul       String   @db.VarChar(255)
  deskripsi   String?  @db.VarChar(1000)
  kelasTarget String[] @db.VarChar(255)
  tgl_unggah  DateTime @default(now())
  lampiran    String?  @db.VarChar(255)
  fileData    Bytes?
  fileName    String?  @db.VarChar(255)
  fileType    String?  @db.VarChar(255)
  fileSize    Int?
  courseId    String   @db.Uuid
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([tgl_unggah])
  @@index([kelasTarget])
}

model Asesmen {
  id                String              @id @default(uuid()) @db.Uuid
  nama              String              @db.VarChar(255)
  deskripsi         String?             @db.VarChar(1000)
  kelasTarget       String[]            @db.VarChar(255)
  tipe              TipeAsesmen         @default(KUIS)
  tipePengerjaan    TipePengerjaan?
  jml_soal          Int?
  durasi            Int?
  tgl_mulai         DateTime?
  tgl_selesai       DateTime?
  lampiran          String?             @db.VarChar(255)
  antiCurang        Boolean             @default(false)
  fileData          Bytes?
  fileName          String?             @db.VarChar(255)
  fileType          String?             @db.VarChar(255)
  fileSize          Int?
  guruId            String              @db.Uuid
  courseId          String              @db.Uuid
  acakJawaban       Boolean             @default(false)
  acakSoal          Boolean             @default(false)
  course            Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  guru              User                @relation(fields: [guruId], references: [id])
  forumDiskusi      ForumDiskusi[]
  nilai             Nilai[]
  pengumpulanProyek PengumpulanProyek[]
  soal              Soal[]

  @@index([guruId])
  @@index([courseId])
  @@index([tipe])
  @@index([tgl_mulai])
  @@index([tgl_selesai])
  @@index([kelasTarget])
}

model Soal {
  id           String         @id @default(uuid()) @db.Uuid
  pertanyaan   String         @db.VarChar(1000)
  gambar       String?        @db.VarChar(255)
  bobot        Int            @default(10)
  tipeJawaban  TipeJawaban    @default(PILIHAN_GANDA)
  asesmenId    String         @db.Uuid
  jawabanSiswa JawabanSiswa[]
  opsi         Opsi[]
  asesmen      Asesmen        @relation(fields: [asesmenId], references: [id], onDelete: Cascade)

  @@index([asesmenId])
}

model Opsi {
  id      String  @id @default(uuid()) @db.Uuid
  teks    String  @db.VarChar(1000)
  isBenar Boolean @default(false)
  soalId  String  @db.Uuid
  soal    Soal    @relation(fields: [soalId], references: [id], onDelete: Cascade)

  @@index([soalId])
}

model JawabanSiswa {
  id           String   @id @default(uuid()) @db.Uuid
  jawaban      String?  @db.VarChar(1000)
  isBenar      Boolean?
  skorDidapat  Float?
  tanggalJawab DateTime @default(now())
  siswaId      String   @db.Uuid
  soalId       String   @db.Uuid
  nilaiId      String?  @db.Uuid
  nilai        Nilai?   @relation(fields: [nilaiId], references: [id], onDelete: Cascade)
  siswa        User     @relation(fields: [siswaId], references: [id])
  soal         Soal     @relation(fields: [soalId], references: [id], onDelete: Cascade)

  @@unique([siswaId, soalId], name: "siswaId_soalId")
  @@index([siswaId])
  @@index([soalId])
  @@index([nilaiId])
}

model Nilai {
  id           String         @id @default(uuid()) @db.Uuid
  skor         Float
  tanggal      DateTime       @default(now())
  siswaId      String         @db.Uuid
  asesmenId    String         @db.Uuid
  jawabanSiswa JawabanSiswa[]
  asesmen      Asesmen        @relation(fields: [asesmenId], references: [id])
  siswa        User           @relation(fields: [siswaId], references: [id])

  @@unique([siswaId, asesmenId], name: "siswaId_asesmenId")
  @@index([siswaId])
  @@index([asesmenId])
  @@index([tanggal])
}

model PBL {
  id          String     @id @default(uuid()) @db.Uuid
  judul       String     @db.VarChar(255)
  deskripsi   String     @db.VarChar(1000)
  tgl_mulai   DateTime
  tgl_selesai DateTime
  lampiran    String?    @db.VarChar(255)
  sintaks     String[]   @db.VarChar(255)
  fileData    Bytes?
  fileName    String?    @db.VarChar(255)
  fileType    String?    @db.VarChar(255)
  fileSize    Int?
  guruId      String     @db.Uuid
  kelompok    Kelompok[]
  guru        User       @relation("PBLDibuat", fields: [guruId], references: [id])

  @@index([guruId])
  @@index([tgl_mulai])
  @@index([tgl_selesai])
  @@map("pbl")
}

model Kelompok {
  id          String              @id @default(uuid()) @db.Uuid
  nama        String              @db.VarChar(255)
  pblId       String              @db.Uuid
  anggota     AnggotaKelompok[]
  pbl         PBL                 @relation(fields: [pblId], references: [id])
  pengumpulan PengumpulanProyek[]

  @@index([pblId])
}

model AnggotaKelompok {
  id         String   @id @default(uuid()) @db.Uuid
  kelompokId String   @db.Uuid
  siswaId    String   @db.Uuid
  kelompok   Kelompok @relation(fields: [kelompokId], references: [id])
  siswa      User     @relation(fields: [siswaId], references: [id])

  @@index([kelompokId])
  @@index([siswaId])
}

model PengumpulanProyek {
  id              String           @id @default(uuid()) @db.Uuid
  catatan         String?          @db.VarChar(1000)
  sourceCode      String?          @db.VarChar(5000)
  output          String?          @db.VarChar(5000)
  tgl_unggah      DateTime         @default(now())
  nilai           Float?
  namaKelompok    String?          @db.VarChar(255)
  ketua           String?          @db.VarChar(255)
  anggota         String[]         @db.VarChar(255)
  fileUrl         String?          @db.VarChar(255)
  status          StatusPengumpulan @default(PENDING)
  feedback        String?          @db.VarChar(1000)
  validatedAt     DateTime?
  validatedBy     String?          @db.VarChar(255)
  kelompokId      String?          @db.Uuid
  siswaId         String?          @db.Uuid
  asesmenId       String?          @db.Uuid
  asesmen         Asesmen?         @relation(fields: [asesmenId], references: [id], onDelete: Cascade)
  kelompok        Kelompok?        @relation(fields: [kelompokId], references: [id])
  siswa           User?            @relation(fields: [siswaId], references: [id])
  profileShowcase ProfileShowcase?

  @@index([kelompokId])
  @@index([siswaId])
  @@index([asesmenId])
  @@index([tgl_unggah])
  @@index([status])
}

model ProfileShowcase {
  id                  String            @id @default(uuid()) @db.Uuid
  judul               String            @db.VarChar(255)
  deskripsi           String?           @db.VarChar(1000)
  nilai               Float
  tanggalDinilai      DateTime          @default(now())
  isPublic            Boolean           @default(true)
  siswaId             String            @db.Uuid
  pengumpulanProyekId String            @unique @db.Uuid
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  pengumpulanProyek   PengumpulanProyek @relation(fields: [pengumpulanProyekId], references: [id], onDelete: Cascade)
  siswa               User              @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@index([siswaId])
  @@index([isPublic])
  @@index([tanggalDinilai])
}

model Enrollment {
  id         String   @id @default(uuid()) @db.Uuid
  enrolledAt DateTime @default(now())
  progress   Int      @default(0)
  courseId   String   @db.Uuid
  siswaId    String   @db.Uuid
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  siswa      User     @relation(fields: [siswaId], references: [id], onDelete: Cascade)

  @@unique([courseId, siswaId])
  @@index([courseId])
  @@index([siswaId])
  @@index([enrolledAt])
}

model ForumDiskusi {
  id        String         @id @default(uuid()) @db.Uuid
  pesan     String         @db.VarChar(2000)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  userId    String         @db.Uuid
  asesmenId String         @db.Uuid
  balasan   BalasanForum[]
  asesmen   Asesmen        @relation(fields: [asesmenId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([asesmenId])
  @@index([userId])
  @@index([createdAt])
}

model BalasanForum {
  id             String       @id @default(uuid()) @db.Uuid
  pesan          String       @db.VarChar(2000)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userId         String       @db.Uuid
  forumDiskusiId String       @db.Uuid
  forumDiskusi   ForumDiskusi @relation(fields: [forumDiskusiId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([forumDiskusiId])
  @@index([userId])
  @@index([createdAt])
}

enum Role {
  ADMIN
  GURU
  SISWA
}

enum TipeAsesmen {
  KUIS
  TUGAS
}

enum TipePengerjaan {
  INDIVIDU
  KELOMPOK
}

enum TipeJawaban {
  PILIHAN_GANDA
  ISIAN
}

enum StatusPengumpulan {
  PENDING
  DINILAI
  REVISI
}
